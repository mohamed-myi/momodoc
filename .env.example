# API Keys (set keys here or configure via the UI settings panel)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# LLM defaults (optional; UI settings take precedence when configured)
# LLM_PROVIDER=claude
# CLAUDE_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-2.5-flash
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5-coder:7b

# Server (optional, defaults shown)
# HOST=127.0.0.1
# PORT=8000

# Data directory (optional; defaults to OS user data dir)
# MOMODOC_DATA_DIR=

# Directory indexing / sync allowlist (comma-separated paths; '.' works for quick local testing)
ALLOWED_INDEX_PATHS=.

# Backend
DEBUG=false
MAX_UPLOAD_SIZE_MB=100
# MAX_FILE_SIZE_MB=200

# Retrieval tuning (optional)
# VECTORDB_SEARCH_NPROBES=24
# VECTORDB_SEARCH_REFINE_FACTOR=2
