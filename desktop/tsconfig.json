{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["@testing-library/jest-dom/vitest"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "outDir": "dist-electron",
    "paths": {
      "@/*": ["./src/renderer/*"],
      "react": ["./node_modules/@types/react"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime"],
      "react/jsx-dev-runtime": ["./node_modules/@types/react/jsx-dev-runtime"],
      "react-dom": ["./node_modules/@types/react-dom"],
      "react-dom/client": ["./node_modules/@types/react-dom/client"],
      "lucide-react": ["./node_modules/lucide-react"],
      "react-markdown": ["./node_modules/react-markdown"],
      "rehype-highlight": ["./node_modules/rehype-highlight"],
      "remark-gfm": ["./node_modules/remark-gfm"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", "dist-electron", "release"]
}
